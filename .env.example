# Ollama Configuration
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MAX_PARALLEL=3

# Proxy Configuration
PROXY_HOST=0.0.0.0
PROXY_PORT=8003
REQUEST_TIMEOUT=300

# VRAM Management
TOTAL_VRAM_MB=80000
VRAM_POLL_INTERVAL=5

# PostgreSQL (Phase 2 - not yet implemented)
POSTGRES_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ollama_logs
POSTGRES_USER=ollama_proxy
POSTGRES_PASSWORD=changeme

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Priority Scoring Weights (tune these!)
PRIORITY_BASE_LOADED=0
PRIORITY_BASE_PARALLEL=150
PRIORITY_BASE_SMALL_SWAP=300
PRIORITY_BASE_LARGE_SWAP=500
PRIORITY_WAIT_TIME_MULTIPLIER=-1
PRIORITY_RATE_LIMIT_MULTIPLIER=5

# Rate Limiting
RATE_LIMIT_WINDOW=600  # seconds (10 minutes)
