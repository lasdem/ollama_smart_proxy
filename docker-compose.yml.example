services:
  ollama-smart-proxy:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: ollama-smart-proxy
    ports:
      - "${PROXY_PORT:-8003}:8003"
    environment:
      # Ollama Configuration
      - OLLAMA_API_BASE=${OLLAMA_API_BASE:-http://localhost:11434}
      - OLLAMA_MAX_PARALLEL=${OLLAMA_MAX_PARALLEL:-3}
      
      # Proxy Configuration
      - PROXY_HOST=${PROXY_HOST:-0.0.0.0}
      - PROXY_PORT=${PROXY_PORT:-8003}
      - REQUEST_TIMEOUT=${REQUEST_TIMEOUT:-300}
      
      # VRAM Configuration
      - TOTAL_VRAM_MB=${TOTAL_VRAM_MB:-80000}
      - VRAM_POLL_INTERVAL=${VRAM_POLL_INTERVAL:-5}
      
      # Priority Weights
      - PRIORITY_BASE_LOADED=${PRIORITY_BASE_LOADED:-0}
      - PRIORITY_BASE_PARALLEL=${PRIORITY_BASE_PARALLEL:-150}
      - PRIORITY_BASE_SMALL_SWAP=${PRIORITY_BASE_SMALL_SWAP:-300}
      - PRIORITY_BASE_LARGE_SWAP=${PRIORITY_BASE_LARGE_SWAP:-500}
      - PRIORITY_WAIT_TIME_MULTIPLIER=${PRIORITY_WAIT_TIME_MULTIPLIER:- -1}
      - PRIORITY_RATE_LIMIT_MULTIPLIER=${PRIORITY_RATE_LIMIT_MULTIPLIER:-5}
      - RATE_LIMIT_WINDOW=${RATE_LIMIT_WINDOW:-600}
      
      # Logging Configuration
      - LOG_FORMAT=${LOG_FORMAT:-human}
      - LOG_LEVEL=${LOG_LEVEL:-INFO}
      - ACCESS_LOG_LEVEL=${ACCESS_LOG_LEVEL:-WARNING}
      
      # Database Configuration
      - DB_TYPE=${DB_TYPE:-sqlite}
      - SQLITE_DB_PATH=${SQLITE_DB_PATH:-./db/smart_proxy.db}
    volumes:
      # Persist database and logs
      - ./db:/app/db
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8003/proxy/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
